---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Voltedge x Supreme | Edició Limitada">
  <Navbar />
  
  <main class="bg-black text-white min-h-screen pt-32 pb-24 px-6 md:px-12 flex items-center relative overflow-hidden">
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-32 items-center">
      
      <div class="flex items-center justify-center min-h-[550px] md:min-h-[750px] relative group select-none">
        <div class="absolute w-[30rem] h-[30rem] bg-red-600/15 rounded-full blur-[160px] pointer-events-none"></div>
        
        <img 
          src="/llauna-supreme.png" 
          alt="Voltedge x Supreme" 
          class="h-[95vh] max-h-[820px] w-auto object-contain transform rotate-3 lg:scale-135 group-hover:rotate-6 group-hover:scale-140 transition duration-500 filter drop-shadow-[0_55px_55px_rgba(255,0,0,0.3)]" 
        />
      </div>

      <div class="flex flex-col justify-center">
        <span class="text-xs font-bold tracking-widest text-red-500 uppercase block mb-3">EDICIÓ LIMITADA - EXCLUSIVA</span>
        <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tight mb-6">
          VOLTEDGE <span class="text-red-600">X SUPREME</span>
        </h1>
        <p class="text-gray-400 text-sm md:text-base mb-8 leading-relaxed max-w-xl">
          Cultura Streetwear convertida en energia líquida puríssima. Unitats ultralimitades a tot el món. Aquesta edició especial no es ven en línia; troba-la exclusivament en punts de venda físics seleccionats.
        </p>

        <div class="bg-neutral-950 p-6 rounded-2xl border border-neutral-900 max-w-lg mb-8">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-4 text-red-500">Punts de venda autoritzats</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div class="bg-neutral-900 border border-neutral-800 p-3 rounded-xl text-center">
              <span class="text-sm font-bold text-white block">Carrefour</span>
              <span class="text-[10px] text-gray-500 uppercase font-medium mt-1 block">Hipermercats</span>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 p-3 rounded-xl text-center">
              <span class="text-sm font-bold text-white block">Caprabo</span>
              <span class="text-[10px] text-gray-500 uppercase font-medium mt-1 block">Centres Selectes</span>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 p-3 rounded-xl text-center">
              <span class="text-sm font-bold text-white block">Locals</span>
              <span class="text-[10px] text-gray-400 uppercase font-bold mt-1 block text-red-500">Autoritzats</span>
            </div>
          </div>
        </div>

        <div class="border-t border-neutral-800 pt-8 max-w-lg">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-4 text-gray-400">Valors per llauna (500ml)</h3>
          <div class="space-y-3 text-xs md:text-sm text-gray-400">
            <div class="flex justify-between border-b border-neutral-900 pb-2"><span>Energia</span><span class="text-white font-medium">15 kcal</span></div>
            <div class="flex justify-between border-b border-neutral-900 pb-2"><span>Grasses / Saturades</span><span class="text-white font-medium">0g / 0g</span></div>
            <div class="flex justify-between border-b border-neutral-900 pb-2"><span>Carbohidrats / Sucres</span><span class="text-white font-medium">0g / 0g</span></div>
            <div class="flex justify-between border-b border-neutral-900 pb-2"><span>Proteïnes</span><span class="text-white font-medium">0g</span></div>
            <div class="flex justify-between pb-2"><span>Sodi</span><span class="text-white font-medium">0.18g</span></div>
          </div>
        </div>
        
        <div class="mt-16 pt-4 w-full block clear-both">
          <a href="/" class="inline-flex items-center gap-2 border border-neutral-700 text-white hover:bg-white hover:text-black font-bold py-3 px-8 rounded-full uppercase tracking-wider text-xs transition duration-300 shadow-lg">
            ← Tornar al catàleg
          </a>
        </div>
      </div>

    </div>
  </main>
</Layout>